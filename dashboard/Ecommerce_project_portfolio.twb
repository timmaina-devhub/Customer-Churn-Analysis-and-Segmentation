              <zone h='98222' id='158' param='vert' type-v2='layout-flow' w='98858' x='571' y='889'>
                <zone fixed-size='280' h='100000' id='141' is-fixed='true' is-scaled='1' param='C:/Users/Startruzy/Downloads/customer_analysis.png' type-v2='bitmap' w='100000' x='0' y='0'>
