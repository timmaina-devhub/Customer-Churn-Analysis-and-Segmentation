      <column caption='Non-churn' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_0342003768872960]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [churn] == 0 then [churn] END' />
      </column>
      <column caption='negative monetary_color' datatype='string' name='[Calculation_0342003812605953]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([monetary]) &lt; 0 THEN &apos;red&apos; ELSE &apos;blue&apos; END' />
      </column>
      <column caption='churn_true' datatype='integer' name='[Calculation_0774661298434048]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [churn] == 1 then [churn] END' />
      </column>
      <column caption='churn_rate' datatype='real' default-format='p0.00%' name='[Calculation_0774661300203521]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0774661298434048]) / COUNT([churn])' />
      </column>
      <column caption='Total active customers' datatype='integer' name='[Calculation_0774661301682178]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([churn])- SUM([Calculation_0774661298434048])' />
      </column>
      <column caption='churn_isnull_zero' datatype='integer' name='[Calculation_0774661304332291]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL(SUM([Calculation_0774661298434048]),0)' />
      </column>
      <column caption='refund_negative_monetary' datatype='real' name='[Calculation_0774661310840840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [monetary] &lt; 0 then [monetary] END' />
      </column>
      <column caption='refund_rate' datatype='real' name='[Calculation_0774661311062025]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Calculation_0774661310840840]) / COUNT([monetary])' />
      </column>
      <column caption='refund_churn_rate' datatype='real' default-format='p0.00%' name='[Calculation_0774661313040394]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Calculation_0774661313708043]) / COUNT([Calculation_0774661310840840])' />
      </column>
      <column caption='if_refund_churn_true' datatype='integer' name='[Calculation_0774661313708043]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [monetary] &lt; 0 THEN [Calculation_0774661298434048] END' />
      </column>
